# BizTrip Budget Guard Environment Variables
# Copy this file to .env and fill in your free API keys.

# App Settings
APP_NAME="BizTrip Budget Guard"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database (SQLite file in current directory)
DATABASE_URL=sqlite:///./biztrip.db

# Groq API (free tier): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
ENABLE_GROQ=true
GROQ_MODEL=llama3-70b-8192
GROQ_FALLBACK_MODEL=mixtral-8x7b-32768

# Amadeus Flight API (test environment, free): https://developers.amadeus.com
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# Kiwi.com Tequila API (free): https://tequila.kiwi.com
TEQUILA_API_KEY=your_tequila_api_key_here

# ExchangeRate-API (free tier, 1500 calls/month): https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
